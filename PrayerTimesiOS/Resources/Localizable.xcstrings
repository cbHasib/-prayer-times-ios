    "Welcome to Prayer Times" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "مرحباً بك في أوقات الصلاة"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রেয়ার টাইমসে স্বাগতম"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Prayer Times'a hoş geldiniz"
          }
        }
      }
    },
    "Where are you?" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أين أنت؟"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনি কোথায়?"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Neredesiniz?"
          }
        }
      }
    },
    "You can fine-tune each prayer — sounds, early reminders, iqamah — in Settings later." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكنك ضبط كل صلاة — الأصوات والتذكيرات المبكرة والإقامة — لاحقاً من الإعدادات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "পরে সেটিংসে প্রতিটি নামাজ — শব্দ, আগাম রিমাইন্ডার, ইকামত — সূক্ষ্মভাবে ঠিক করতে পারবেন।"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her namazı — sesler, erken hatırlatmalar, kamet — daha sonra Ayarlar'da ince ayarlayabilirsiniz."
          }
        }
      }
    },
    "You're all set" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "كل شيء جاهز"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সব প্রস্তুত"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her şey hazır"
          }
        }
      }
    },
    "You're All Set!" : {

    },
    "Your Location" : {

    },
    "Your mosque's jamaat times" : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أوقات جماعة مسجدك"
