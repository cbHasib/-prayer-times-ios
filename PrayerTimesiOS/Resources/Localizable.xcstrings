    "Let's set things up in a few quick steps. You can change any of this later in Settings." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لنُعِدّ التطبيق في بضع خطوات سريعة. يمكنك تغيير أيٍّ من ذلك لاحقاً من الإعدادات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "চলুন কয়েকটি দ্রুত ধাপে সেট আপ করি। পরে সেটিংস থেকে যেকোনো কিছু পরিবর্তন করতে পারবেন।"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Birkaç hızlı adımda kuralım. Bunların tümünü daha sonra Ayarlar'dan değiştirebilirsiniz."
          }
        }
      }
    },
