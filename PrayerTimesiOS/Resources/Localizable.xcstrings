        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "আপনার মসজিদ যে সময় ঘোষণা করে তা লিখুন। উপরের মিনিট অনুযায়ী প্রতিটির আগে আজানের রিমাইন্ডার বাজবে।"
