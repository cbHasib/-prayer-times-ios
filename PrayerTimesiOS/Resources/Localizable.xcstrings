    "Successful indeed are the believers — those who are humble in their prayer." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "قَدْ أَفْلَحَ الْمُؤْمِنُونَ، الَّذِينَ هُمْ فِي صَلَاتِهِمْ خَاشِعُونَ."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "নিশ্চয়ই সফল হয়েছে মুমিনগণ, যারা তাদের নামাজে বিনয়াবনত।"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Müminler gerçekten kurtuluşa ermiştir; onlar ki namazlarında huşû içindedir."
          }
        }
      }
    },
