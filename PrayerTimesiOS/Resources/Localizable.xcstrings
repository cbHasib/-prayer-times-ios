    "Enter the times your mosque announces. The Adhan reminder fires the minutes above before each." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أدخل الأوقات التي يعلنها مسجدك. ينطلق تذكير الأذان بالدقائق أعلاه قبل كل وقت."
          }
