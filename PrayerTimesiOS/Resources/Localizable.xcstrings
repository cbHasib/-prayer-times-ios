    "A nudge — and optionally the Adhan — at each prayer." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تنبيه — والأذان اختيارياً — عند كل صلاة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "প্রতি নামাজে একটি বার্তা — এবং চাইলে আজান।"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her namazda bir hatırlatma — ve isterseniz ezan."
          }
        }
      }
    },
